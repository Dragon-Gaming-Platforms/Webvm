FROM --platform=i386 i386/debian:bookworm
ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get clean && apt-get update && apt-get -y upgrade

RUN apt-get -y install \
    gcc \
    g++ \
    python3 \
    python3-pip \
    vim \
    git \
    curl \
    wget \
    nodejs \
    npm \
    rustc \
    cargo \
    golang \
    make \
    perl \
    ruby \
    lua5.4 \
    php \
    unzip \
    zip \
    tar \
    gzip \
    bzip2 \
    xz-utils \
    file \
    less \
    dialog \
    whiptail \
    cowsay \
    netcat-openbsd \
    fakeroot \
    dbus \
    hexedit \
    patch \
    wamerican \
    ucf \
    manpages \
    luajit \
    python3-venv \
    python3-dev \
    ruby-bundler \
    ruby-dev \
    cmake \
    autoconf \
    automake \
    pkg-config \
    openssh-client

# Install TypeScript and common Node packages globally
RUN npm install -g \
    typescript \
    ts-node \
    yarn \
    nodemon

# Install essential Python packages
RUN pip3 install --break-system-packages \
    blessed \
    psutil \
    requests \
    flask \
    pytest \
    click

# Create user
RUN useradd -m user && echo "user:password" | chpasswd

# Create apps directory
RUN mkdir -p /home/user/apps

# Copy scripts
COPY scripts/install.sh /usr/local/bin/install
RUN chmod +x /usr/local/bin/install

COPY scripts/welcome.sh /etc/profile.d/welcome.sh
RUN chmod +x /etc/profile.d/welcome.sh

# Clone the OS UI
RUN mkdir -p /home/user/apps/Dragon-Gaming-Platforms && \
    git clone https://github.com/Dragon-Gaming-Platforms/myos-ui \
    /home/user/apps/Dragon-Gaming-Platforms/myos-ui || \
    echo "UI repo not found yet, will fall back to bash"

# Set ownership
RUN chown -R user:user /home/user

WORKDIR /home/user/
ENV HOME="/home/user" TERM="xterm" USER="user" \
    SHELL="/bin/bash" EDITOR="vim" \
    LANG="en_US.UTF-8" LC_ALL="C" \
    PATH="/home/user/.cargo/bin:$PATH"

RUN echo 'root:password' | chpasswd

# Launch UI on startup (falls back to bash if UI not found)
CMD ["/bin/bash", "-c", "if [ -f /home/user/apps/Dragon-Gaming-Platforms/myos-ui/main.py ]; then python3 /home/user/apps/Dragon-Gaming-Platforms/myos-ui/main.py; else echo 'OS UI not found. Falling back to bash...'; /bin/bash; fi"]
